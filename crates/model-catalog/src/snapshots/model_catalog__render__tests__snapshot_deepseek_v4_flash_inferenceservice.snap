---
source: crates/model-catalog/src/render.rs
expression: value
---
apiVersion: serving.kserve.io/v1beta1
kind: InferenceService
metadata:
  annotations:
    homelab.saavylab.dev/model-id: deepseek-ai/DeepSeek-V4-Flash
  labels:
    app.kubernetes.io/managed-by: homelab-mcp
    homelab.saavylab.dev/recipe-id: deepseek-v4-flash
  name: deepseek-v4-flash
  namespace: ai
spec:
  predictor:
    maxReplicas: 1
    minReplicas: 1
    model:
      modelFormat:
        name: vllm
      resources:
        limits:
          nvidia.com/gpu: "1"
        requests:
          cpu: "2"
          memory: 16Gi
          nvidia.com/gpu: "1"
